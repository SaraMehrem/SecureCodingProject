nt info</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Low</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>fceece9d-be35-4ded-8001-5f5d8e9a93d5</b:SourceGuid><b:State>NotApplicable</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>95ebfb18-d739-47f5-bfca-68768078f89b</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D4</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D5fceece9d-be35-4ded-8001-5f5d8e9a93d58a7046d3-7d07-4b32-b72c-9b8800c4c6c495ebfb18-d739-47f5-bfca-68768078f89b</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>MM-LAP\MM</b:ChangedBy><b:DrawingSurfaceGuid>57c6a81d-ab89-41f7-8386-d21be1669bb2</b:DrawingSurfaceGuid><b:FlowGuid>8a7046d3-7d07-4b32-b72c-9b8800c4c6c4</b:FlowGuid><b:Id>58</b:Id><b:InteractionKey>fceece9d-be35-4ded-8001-5f5d8e9a93d5:8a7046d3-7d07-4b32-b72c-9b8800c4c6c4:95ebfb18-d739-47f5-bfca-68768078f89b</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2023-12-26T05:31:21.355575+03:00</b:ModifiedAt><b:Priority>Low</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Store Inaccessible</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>An external agent prevents access to a data store on the other side of the trust boundary.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>the web server and the database server in the same data center</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Patient info</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Low</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>fceece9d-be35-4ded-8001-5f5d8e9a93d5</b:SourceGuid><b:State>NotApplicable</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>95ebfb18-d739-47f5-bfca-68768078f89b</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D5</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>R6a8c672b4-71bb-401e-8def-63be97118b15f9837c2f-54ef-46db-8957-265af5c5e39e244db977-b5aa-4b19-b0cf-53040dbd7113</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>MM-LAP\MM</b:ChangedBy><b:DrawingSurfaceGuid>57c6a81d-ab89-41f7-8386-d21be1669bb2</b:DrawingSurfaceGuid><b:FlowGuid>f9837c2f-54ef-46db-8957-265af5c5e39e</b:FlowGuid><b:Id>59</b:Id><b:InteractionKey>a8c672b4-71bb-401e-8def-63be97118b15:f9837c2f-54ef-46db-8957-265af5c5e39e:244db977-b5aa-4b19-b0cf-53040dbd7113</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2024-01-11T14:20:16.3709592+03:00</b:ModifiedAt><b:Priority>Low</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Potential Data Repudiation by Retrieve doctor info Process</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Repudiation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Repudiation threats involve an adversary denying that something happened.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Retrieve doctor info Process claims that it did not receive data from a source outside the trust boundary. </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>the Retrieve doctor info Process will not be completed if it did not receive the data from Doctor info database </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Doctor info</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Low</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>a8c672b4-71bb-401e-8def-63be97118b15</b:SourceGuid><b:State>NotApplicable</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>244db977-b5aa-4b19-b0cf-53040dbd7113</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>R6</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D3a8c672b4-71bb-401e-8def-63be97118b15f9837c2f-54ef-46db-8957-265af5c5e39e244db977-b5aa-4b19-b0cf-53040dbd7113</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>MM-LAP\MM</b:ChangedBy><b:DrawingSurfaceGuid>57c6a81d-ab89-41f7-8386-d21be1669bb2</b:DrawingSurfaceGuid><b:FlowGuid>f9837c2f-54ef-46db-8957-265af5c5e39e</b:FlowGuid><b:Id>60</b:Id><b:InteractionKey>a8c672b4-71bb-401e-8def-63be97118b15:f9837c2f-54ef-46db-8957-265af5c5e39e:244db977-b5aa-4b19-b0cf-53040dbd7113</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2023-12-26T05:06:00.5447225+03:00</b:ModifiedAt><b:Priority>Low</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Potential Process Crash or Stop for Retrieve doctor 