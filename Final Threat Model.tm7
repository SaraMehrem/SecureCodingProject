</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>An external agent prevents access to a data store on the other side of the trust boundary.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>the web server and the database server in the same data center</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Doctor info</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Low</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>a8c672b4-71bb-401e-8def-63be97118b15</b:SourceGuid><b:State>NotApplicable</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>2cfff8e7-b780-49f9-93a0-8f71a3b3c5a6</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D5</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>E6a8c672b4-71bb-401e-8def-63be97118b156fb841a1-7155-4aea-8eb1-05b51e8434962cfff8e7-b780-49f9-93a0-8f71a3b3c5a6</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>MM-LAP\MM</b:ChangedBy><b:DrawingSurfaceGuid>57c6a81d-ab89-41f7-8386-d21be1669bb2</b:DrawingSurfaceGuid><b:FlowGuid>6fb841a1-7155-4aea-8eb1-05b51e843496</b:FlowGuid><b:Id>75</b:Id><b:InteractionKey>a8c672b4-71bb-401e-8def-63be97118b15:6fb841a1-7155-4aea-8eb1-05b51e843496:2cfff8e7-b780-49f9-93a0-8f71a3b3c5a6</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2023-12-26T06:03:28.4591007+03:00</b:ModifiedAt><b:Priority>Low</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Login Process May be Subject to Elevation of Privilege Using Remote Code Execution</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Elevation Of Privilege</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>A user subject gains increased capability or privilege by taking advantage of an implementation bug.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Doctor info may be able to remotely execute code for Login Process.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>sanitization</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Doctor info</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Low</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>a8c672b4-71bb-401e-8def-63be97118b15</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>2cfff8e7-b780-49f9-93a0-8f71a3b3c5a6</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>E6</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>E7a8c672b4-71bb-401e-8def-63be97118b156fb841a1-7155-4aea-8eb1-05b51e8434962cfff8e7-b780-49f9-93a0-8f71a3b3c5a6</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>MM-LAP\MM</b:ChangedBy><b:DrawingSurfaceGuid>57c6a81d-ab89-41f7-8386-d21be1669bb2</b:DrawingSurfaceGuid><b:FlowGuid>6fb841a1-7155-4aea-8eb1-05b51e843496</b:FlowGuid><b:Id>76</b:Id><b:InteractionKey>a8c672b4-71bb-401e-8def-63be97118b15:6fb841a1-7155-4aea-8eb1-05b51e843496:2cfff8e7-b780-49f9-93a0-8f71a3b3c5a6</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2023-12-26T06:08:50.87268+03:00</b:ModifiedAt><b:Priority>Low</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Elevation by Changing the Execution Flow in Login Process</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Elevation Of Privilege</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>A user subject gains increased capability or privilege by taking advantage of an implementation bug.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>An attacker may pass data into Login Process in order to change the flow of program execution within Login Process to the attacker's choosing.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>sanitization</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Doctor info</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Low</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>a8c672b4-71bb-401e-8def-63be97118b15</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>2cfff8e7-b780-49f9-93a0-8f71a3b3c5a6</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>E7</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S136789562-6c38-4b13-b70f-36c84eb6384a32b8d979-304d-450b-bbe4-438b650669b323f0fd49-1986-40db-b840-15cc5dff95d7</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>MM-LAP\MM</b:ChangedBy><b:DrawingSurfaceGuid>57c6a81d-ab89-41f7-8386-d21be1669bb2</b:DrawingSurfaceGuid><b:FlowGuid>32b8d979-304d-450b-bbe4-438b650669b3</b:FlowGuid><b:Id>77</b:Id><b:InteractionKey>36789562-6c38-4b13-b70f-36c84eb6384a:32b8d979-304d-450b-bbe4-438b650669b3:23f0fd49-1986-40db-b840-15cc5dff95d7</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2024-01-11T14:17:29.41993+03:00</b:ModifiedAt><b:Priority>Low</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Spoofing the Receive and insert medical info Process Process</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Spoofing is when a process or entity is something other than its claimed identity. Examples include substituting a process, a file, website or a network address.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Receive and insert medical info Process may be spoofed by an attacker and this may lead to unauthorized access to Medical info. </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>username and password auththentication used and strong password policy</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Medical info</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Low</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>36789562-6c38-4b13-b70f-36c84eb6384a</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>23f0fd49-1986-40db-b840-15cc5dff95d7</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S1</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>T1836789562-6c38-4b13-b70f-36c84eb6384a32b8d979-304d-450b-bbe4-438b650669b323f0fd49-1986-40db-b840-15cc5dff95d7</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>MM-LAP\MM</b:ChangedBy><b:DrawingSurfaceGuid>57c6a81d-ab89-41f7-8386-d21be1669bb2</b:DrawingSurfaceGuid><b:FlowGuid>32b8d979-304d-450b-bbe4-438b650669b3</b:FlowGuid><b:Id>78</b:Id><b:InteractionKey>36789562-6c38-4b13-b70f-36c84eb6384a:32b8d979-304d-450b-bbe4-438b650669b3:23f0fd49-1986-40db-b840-15cc5dff95d7</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2024-01-11T14:19:41.9441348+03:00</b:ModifiedAt><b:Priority>Low</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>The Medical info Data Store Could Be Corrupted</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Tampering</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Tampering is the act of altering the bits. Tampering with a process involves changing bits in the running process. Similarly, Tampering with a data flow involves changing bits on the wire or between two running processes.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Data flowing across Medical info may be tampered with by an attacker. This may lead to corruption of Medical info. </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>store data as a string in the database</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Medical info</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Low</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>36789562-6c38-4b13-b70f-36c84eb6384a</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>23f0fd49-1986-40db-b840-15cc5dff95d7</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>T18</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>R836789562-6c38-4b13-b70f-36c84eb6384a32b8d979-304d-450b-bbe4-438b650669b323f0fd49-1986-40db-b840-15cc5dff95d7</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>MM-LAP\MM</b:ChangedBy><b:DrawingSurfaceGuid>57c6a81d-ab89-41f7-8386-d21be1669bb2</b:DrawingSurfaceGuid><b:FlowGuid>32b8d979-304d-450b-bbe4-438b650669b3</b:FlowGuid><b:Id>79</b:Id><b:InteractionKey>36789562-6c38-4b13-b70f-36c84eb6384a:32b8d979-304d-450b-bbe4-438b650669b3:23f0fd49-1986-40db-b840-15cc5dff95d7</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2024-01-11T14:21:19.0251241+03:00</b:ModifiedAt><b:Priority>Low</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Store Denies Medical info Potentially Writing Data</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Repudiation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Repudiation threats involve an adversary denying that something happened.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Medical info claims that it did not write data received from an entity on the other side of the trust boundary. </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>all the transaction to the Medical info database are logged </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Medical info</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Low</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>36789562-6c38-4b13-b70f-36c84eb6384a</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>23f0fd49-1986-40db-b840-15cc5dff95d7</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>R8</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D436789562-6c38-4b13-b70f-36c84eb6384a32b8d979-304d-450b-bbe4-438b650669b323f0fd49-1986-40db-b840-15cc5dff95d7</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>MM-LAP\MM</b:ChangedBy><b:DrawingSurfaceGuid>57c6a81d-ab89-41f7-8386-d21be1669bb2</b:DrawingSurfaceGuid><b:FlowGuid>32b8d979-304d-450b-bbe4-438b650669b3</b:FlowGuid><b:Id>80</b:Id><b:InteractionKey>36789562-6c38-4b13-b70f-36c84eb6384a:32b8d979-304d-450b-bbe4-438b650669b3:23f0fd49-1986-40db-b840-15cc5dff95d7</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2023-12-26T05:22:07.9096558+03:00</b:ModifiedAt><b:Priority>Low</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Flow Medical info Is Potentially Interrupted</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Val