yValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Spoofing is when a process or entity is something other than its claimed identity. Examples include substituting a process, a file, website or a network address.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Doctor may be spoofed by an attacker and this may lead to unauthorized access to Receive and insert medical info Process.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>username and password authentication is used and strong password policy</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Medical info</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Low</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>6a9556ab-7fcd-4a39-a048-e5cb47da34b7</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>36789562-6c38-4b13-b70f-36c84eb6384a</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S3</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>E56a9556ab-7fcd-4a39-a048-e5cb47da34b76e36f66a-c30d-494e-b33a-bf9586514d5136789562-6c38-4b13-b70f-36c84eb6384a</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>MM-LAP\MM</b:ChangedBy><b:DrawingSurfaceGuid>57c6a81d-ab89-41f7-8386-d21be1669bb2</b:DrawingSurfaceGuid><b:FlowGuid>6e36f66a-c30d-494e-b33a-bf9586514d51</b:FlowGuid><b:Id>26</b:Id><b:InteractionKey>6a9556ab-7fcd-4a39-a048-e5cb47da34b7:6e36f66a-c30d-494e-b33a-bf9586514d51:36789562-6c38-4b13-b70f-36c84eb6384a</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2023-12-28T11:46:00.448896+03:00</b:ModifiedAt><b:Priority>Low</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Elevation Using Impersonation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Elevation Of Privilege</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>A user subject gains increased capability or privilege by taking advantage of an implementation bug.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Receive and insert medical info Process may be able to impersonate the context of Doctor in order to gain additional privilege.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>apply the least privileges and input sanitization</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Medical info</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Low</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>6a9556ab-7fcd-4a39-a048-e5cb47da34b7</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>36789562-6c38-4b13-b70f-36c84eb6384a</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>E5</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S7.136789562-6c38-4b13-b70f-36c84eb6384a32b8d979-304d-450b-bbe4-438b650669b323f0fd49-1986-40db-b840-15cc5dff95d7</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>MM-LAP\MM</b:ChangedBy><b:DrawingSurfaceGuid>57c6a81d-ab89-41f7-8386-d21be1669bb2</b:DrawingSurfaceGuid><b:FlowGuid>32b8d979-304d-450b-bbe4-438b650669b3</b:FlowGuid><b:Id>27</b:Id><b:InteractionKey>36789562-6c38-4b13-b70f-36c84eb6384a:32b8d979-304d-450b-bbe4-438b650669b3:23f0fd49-1986-40db-b840-15cc5dff95d7</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2024-01-11T14:17:04.1492925+03:00</b:ModifiedAt><b:Priority>Low</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Spoofing of Destination Data Store Medical info</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Spoofing is when a process or entity is something other than its claimed identity. Examples include substituting a process, a file, website or a network address.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Medical info may be spoofed by an attacker and this may lead to data being written to the attacker's target instead of Medical info. </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>sanitization and store data as a string in the database</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Medical info</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Low</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>36789562-6c38-4b13-b70f-36c84eb6384a</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>23f0fd49-1986-40db-b840-15cc5dff95d7</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S7.1</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D236789562-6c38-4b13-b70f-36c84eb6384a32b8d979-304d-450b-bbe4-438b650669b323f0fd49-1986-40db-b840-15cc5dff95d7</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>MM-LAP\MM</b:ChangedBy><b:DrawingSurfaceGuid>57c6a81d-ab89-41f7-8386-d21be1669bb2</b:DrawingSurfaceGuid><b:FlowGuid>32b8d979-304d-450b-bbe4-438b650669b3</b:FlowGuid><b:Id>28</b:Id><b:InteractionKey>36789562-6c38-4b13-b70f-36c84eb6384a:32b8d979-304d-450b-bbe4-438b650669b3:23f0fd49-1986-40db-b840-15cc5dff95d7</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2024-01-11T14:24:13.0983241+03:00</b:ModifiedAt><b:Priority>Low</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Potential Excessive Resource Consumption for Receive and insert medical info Process or Medical info</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Does Receive and insert medical info Process or Medical info take explicit steps to control resource consumption? Resource consumption attacks can be hard to deal with, and there are times that it makes sense to let the OS do the job. </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>sanitization </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Medical info</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Low</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>36789562-6c38-4b13-b70f-36c84eb6384a<