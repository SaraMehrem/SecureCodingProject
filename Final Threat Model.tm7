ue></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Low</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>325f951e-256e-4c91-a98d-8cbd302a314f</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>2cfff8e7-b780-49f9-93a0-8f71a3b3c5a6</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>E7</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S82cfff8e7-b780-49f9-93a0-8f71a3b3c5a6ddd228d5-e00f-4014-a4f7-ebc9d52aba5f325f951e-256e-4c91-a98d-8cbd302a314f</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>MM-LAP\MM</b:ChangedBy><b:DrawingSurfaceGuid>57c6a81d-ab89-41f7-8386-d21be1669bb2</b:DrawingSurfaceGuid><b:FlowGuid>ddd228d5-e00f-4014-a4f7-ebc9d52aba5f</b:FlowGuid><b:Id>88</b:Id><b:InteractionKey>2cfff8e7-b780-49f9-93a0-8f71a3b3c5a6:ddd228d5-e00f-4014-a4f7-ebc9d52aba5f:325f951e-256e-4c91-a98d-8cbd302a314f</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2024-01-11T14:17:36.9316576+03:00</b:ModifiedAt><b:Priority>Low</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Spoofing of the Record Keeper External Destination Entity</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Spoofing is when a process or entity is something other than its claimed identity. Examples include substituting a process, a file, website or a network address.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Record Keeper may be spoofed by an attacker and this may lead to data being sent to the attacker's target instead of Record Keeper. </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>username and password auththentication is used and strong password policy</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Record Keeper info</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Low</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>2cfff8e7-b780-49f9-93a0-8f71a3b3c5a6</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>325f951e-256e-4c91-a98d-8cbd302a314f</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S8</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>R72cfff8e7-b780-49f9-93a0-8f71a3b3c5a6ddd228d5-e00f-4014-a4f7-ebc9d52aba5f325f951e-256e-4c91-a98d-8cbd302a314f</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>MM-LAP\MM</b:ChangedBy><b:DrawingSurfaceGuid>57c6a81d-ab89-41f7-8386-d21be1669bb2</b:DrawingSurfaceGuid><b:FlowGuid>ddd228d5-e00f-4014-a4f7-ebc9d52aba5f</b:FlowGuid><b:Id>89</b:Id><b:InteractionKey>2cfff8e7-b780-49f9-93a0-8f71a3b3c5a6:ddd228d5-e00f-4014-a4f7-ebc9d52aba5f:325f951e-256e-4c91-a98d-8cbd302a314f</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2024-01-11T14:20:25.992864+03:00</b:ModifiedAt><b:Priority>Low</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>External Entity Record Keeper Potentially Denies Receiving Data</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Repudiation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Repudiation threats involve an adversary denying that something happened.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Record Keeper claims that it did not receive data from a process on the other side of the trust boundary. </a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>all the activity in Login Process is logged</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Record Keeper info</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Low</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>2cfff8e7-b780-49f9-93a0-8f71a3b3c5a6</b:SourceGuid><b:State>Mitigated</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>325f951e-256e-4c91-a98d-8cbd302a314f</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>R7</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D42cfff8e7-b780-49f9-93a0-8f71a3b3c5a6ddd228d5-e00f-4014-a4f7-ebc9d52aba5f325f951e-256e-4c91-a98d-8cbd302a314f</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>MM-LAP\MM</b:ChangedBy><b:DrawingSurfaceGuid>57c6a81d-ab89-41f7-8386-d21be1669bb2</b:DrawingSurfaceGuid><b:FlowGuid>ddd228d5-e00f-4014-a4f7-ebc9d52aba5f</b:FlowGuid><b:Id>90</b:Id><b:InteractionKey>2cfff8e7-b780-49f9-93a0-8f71a3b3c5a6:ddd228d5-e00f-4014-a4f7-ebc9d52aba5f:325f951e-256e-4c91-a98d-8cbd302a314f</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2023-12-26T05:23:09.6288156+03:00</b:ModifiedAt><b:Priority>Low</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>Data Flow Record Keeper info Is Potentially Interrupted</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Denial of Service happens when the process or a datastore is not able to service incoming requests or perform up to spec.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>An external agent interrupts data flowing across a trust boundary in either direction.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>StateInformation</a:Key><a:Value>standard mitigation for MITM attacks such as firewalls and DNS configrations are out of scope</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Record Keeper info</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Low</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>2cfff8e7-b780-49f9-93a0-8f71a3b3c5a6</b:SourceGuid><b:State>NotApplicable</b:State><b:StateInformation i:nil="true"/><b:TargetGuid>325f951e-256e-4c91-a98d-8cbd302a314f</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D4</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>R66a9556ab-7fcd-4a39-a048-e5cb47da34b76418a921-e201-4e7f-8db6-0b52b172ec522cfff8e7-b780-49f9-93a0-8f71a3b3c5a6</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>MM-LAP\MM</b:ChangedBy><b:DrawingSurfaceGuid>57c6a81d-ab89-41f7-8386-d21be1669bb2</b:DrawingSurfaceGuid><b:FlowGuid>6418a921-e201-4e7f-8db6-0b52b172ec52</b:FlowGuid><b:Id>91</b:Id><b:InteractionKey>6a9556ab-7fcd-4a39-